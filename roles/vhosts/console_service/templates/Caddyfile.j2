{# 渲染时直接展开域名: caddy 由 systemd 运行, 没有 SERVED_DOMAINS 环境变量;
   {$SERVED_DOMAINS} 占位符会展开为空键, caddy validate 报
   "server block without any key is global configuration" #}
{{ console_service_served_domains }} {
  encode zstd gzip

  reverse_proxy 127.0.0.1:{{ console_service_port }} {
    header_up Host {host}
    header_up X-Forwarded-Host {host}
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-For {remote_host}
  }
}
