# AI Workspace Image Configurations
XWORKSPACE_CONSOLE_IMAGE=ghcr.io/ai-workspace/xworkspace-console:latest
XWORKMATE_BRIDGE_IMAGE=ghcr.io/ai-workspace/xworkmate-bridge:latest
POSTGRES_IMAGE=postgres:17
VAULT_IMAGE=hashicorp/vault:latest
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest
QMD_IMAGE=ghcr.io/ai-workspace/qmd:latest
X_MEMORY_HUB_IMAGE=ghcr.io/ai-workspace/x-memory-hub:latest

# Postgres Secrets
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=postgres

# Vault Configuration
# Vault tokens and auto-unseal settings should be configured here.

# Caddy Configuration
SERVED_DOMAINS=workspace.local api.local
