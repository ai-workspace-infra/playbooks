# PostgreSQL Configuration
POSTGRES_IMAGE=postgres:17
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=postgres

# Stunnel Configuration
STUNNEL_SERVER_IMAGE=ghcr.io/x-evor/stunnel-server:2330d36
STUNNEL_CLIENT_IMAGE=ghcr.io/x-evor/stunnel-client:latest
STUNNEL_ACCEPT_PORT=15432

# Accounts Service Configuration
ACCOUNTS_IMAGE=ghcr.io/x-evor/accounts:70c6a3f8
# ACCOUNTS_DATABASE_URL is constructed in docker-compose.yml by default, 
# but can be overridden here.
# ACCOUNTS_DATABASE_URL=postgres://postgres:password@stunnel-client:5432/account?sslmode=disable

# Billing Service Configuration
BILLING_IMAGE=ghcr.io/ai-workspace-services/billing-service:latest
BILLING_DB_PASSWORD=your_secure_billing_db_password
# BILLING_DATABASE_URL is constructed in docker-compose.yml by default,
# but can be overridden here.
# BILLING_DATABASE_URL=postgres://svcplus_vps:password@stunnel-client:5432/account?sslmode=disable

# Console Service Configuration
CONSOLE_IMAGE=ghcr.io/ai-workspace-services/console:latest

# Caddy Configuration
SERVED_DOMAINS=accounts.local billing.local console.local
