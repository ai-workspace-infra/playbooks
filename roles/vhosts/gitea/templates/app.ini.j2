APP_NAME = code.svc.plus
RUN_USER = git
WORK_PATH = /var/lib/gitea
RUN_MODE = prod

[server]
LOCAL_ROOT_URL = http://localhost:3001/
SSH_DOMAIN = code.svc.plus
DOMAIN = code.svc.plus
HTTP_PORT = 3001
ROOT_URL = https://code.svc.plus/
APP_DATA_PATH = /var/lib/gitea/data
DISABLE_SSH = false
SSH_PORT = 22
LFS_START_SERVER = true
{% if gitea_lfs_jwt_secret | default('') %}
LFS_JWT_SECRET = {{ gitea_lfs_jwt_secret }}
{% endif %}
OFFLINE_MODE = true

[database]
MAX_OPEN_CONNS = 5
MAX_IDLE_CONNS = 2
DB_TYPE = postgres
HOST = {{ gitea_db_host | default('127.0.0.1:5432') }}
NAME = {{ gitea_db_name | default('gitea') }}
USER = {{ gitea_db_user | default('gitea') }}
PASSWD = {{ gitea_db_password }}
SCHEMA = 
SSL_MODE = disable
PATH = /var/lib/gitea/data/gitea.db
LOG_SQL = false

[repository]
ROOT = /var/lib/gitea/data/gitea-repositories

[storage]
STORAGE_TYPE = minio
ENDPOINT = {{ gitea_s3_endpoint | default('s3.us-east-1.amazonaws.com') }}
ACCESS_KEY_ID = {{ gitea_s3_access_key }}
SECRET_ACCESS_KEY = {{ gitea_s3_secret_key }}
BUCKET = {{ gitea_s3_bucket }}
LOCATION = {{ gitea_s3_region | default('us-east-1') }}
USE_SSL = true
MINIO_ENDPOINT = {{ gitea_s3_endpoint | default('s3.us-east-1.amazonaws.com') }}
MINIO_ACCESS_KEY_ID = {{ gitea_s3_access_key }}
MINIO_SECRET_ACCESS_KEY = {{ gitea_s3_secret_key }}
MINIO_BUCKET = {{ gitea_s3_bucket }}
MINIO_LOCATION = {{ gitea_s3_region | default('us-east-1') }}
MINIO_USE_SSL = true

[storage.minio]
ENDPOINT = {{ gitea_s3_endpoint | default('s3.us-east-1.amazonaws.com') }}
ACCESS_KEY_ID = {{ gitea_s3_access_key }}
SECRET_ACCESS_KEY = {{ gitea_s3_secret_key }}
BUCKET = {{ gitea_s3_bucket }}
LOCATION = {{ gitea_s3_region | default('us-east-1') }}
USE_SSL = true
MINIO_ENDPOINT = {{ gitea_s3_endpoint | default('s3.us-east-1.amazonaws.com') }}
MINIO_ACCESS_KEY_ID = {{ gitea_s3_access_key }}
MINIO_SECRET_ACCESS_KEY = {{ gitea_s3_secret_key }}
MINIO_BUCKET = {{ gitea_s3_bucket }}
MINIO_LOCATION = {{ gitea_s3_region | default('us-east-1') }}
MINIO_USE_SSL = true

[attachment]
STORAGE_TYPE = minio

[lfs]
STORAGE_TYPE = minio
PATH = /var/lib/gitea/data/lfs

[avatar]
STORAGE_TYPE = minio

[repo-archive]
STORAGE_TYPE = minio

[packages]
STORAGE_TYPE = minio

[mailer]
ENABLED = false

[service]
REGISTER_EMAIL_CONFIRM = false
ENABLE_NOTIFY_MAIL = false
DISABLE_REGISTRATION = false
ALLOW_ONLY_EXTERNAL_REGISTRATION = false
ENABLE_CAPTCHA = false
REQUIRE_SIGNIN_VIEW = false
DEFAULT_KEEP_EMAIL_PRIVATE = false
DEFAULT_ALLOW_CREATE_ORGANIZATION = true
DEFAULT_ENABLE_TIMETRACKING = true
NO_REPLY_ADDRESS = noreply.localhost

[openid]
ENABLE_OPENID_SIGNIN = true
ENABLE_OPENID_SIGNUP = true

[cron.update_checker]
ENABLED = false

[session]
PROVIDER = memory

[log]
MODE = console
LEVEL = info
ROOT_PATH = /var/lib/gitea/log

[repository.pull-request]
DEFAULT_MERGE_STYLE = merge

[repository.signing]
DEFAULT_TRUST_MODEL = committer

[security]
INSTALL_LOCK = true
{% if gitea_internal_token | default('') %}
INTERNAL_TOKEN = {{ gitea_internal_token }}
{% endif %}
PASSWORD_HASH_ALGO = pbkdf2

[oauth2]
{% if gitea_oauth2_jwt_secret | default('') %}
JWT_SECRET = {{ gitea_oauth2_jwt_secret }}
{% endif %}

[actions]
ENABLED = true

[indexer]
REPO_INDEXER_ENABLED = false
MAX_INDEXER_CONN = 5
