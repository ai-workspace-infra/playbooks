#!/bin/sh
set -eu
CHROME_BIN={{ xfce_browser_binary }}
if [ ! -x "$CHROME_BIN" ]; then
  echo "chromium-xrdp: $CHROME_BIN is not installed" >&2
  exit 127
fi
if [ "${XDG_SESSION_TYPE:-}" = x11 ] && [ -n "${DISPLAY:-}" ]; then
  profile_dir="${CHROME_USER_DATA_DIR:-$HOME/.config/google-chrome-xrdp}"
  install -d -m 700 "$profile_dir"
  exec "$CHROME_BIN" \
    --user-data-dir="$profile_dir" \
    --password-store=basic \
    --no-first-run \
    --no-default-browser-check \
    --disable-gpu-compositing \
    "$@"
fi
exec "$CHROME_BIN" "$@"
