observability.svc.plus {
    # Root redirects to Grafana
    redir / /grafana/

    # Grafana (可视化大盘面板)
    handle /grafana/* {
        reverse_proxy 127.0.0.1:{{ observability_grafana_port | default('3030') }}
    }
    handle /grafana {
        redir * /grafana/
    }

    # VictoriaMetrics / Prometheus (指标接收与查询) - Currently Prometheus on 9090
    handle_path /ingest/metrics/* {
        reverse_proxy 127.0.0.1:{{ observability_prometheus_port | default('9090') }}
    }
}
